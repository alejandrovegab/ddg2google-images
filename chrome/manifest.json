{
  "manifest_version": 3,
  "name": "DDG Images to Google Images",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["*://duckduckgo.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.google.com/search*"],
      "js": ["google.js"],
      "run_at": "document_start"
    }
  ]
}