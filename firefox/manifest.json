{
  "manifest_version": 2,
  "name": "DDG Images to Google Images",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "ddg-images-personal@alexochunk",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://duckduckgo.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.google.com/search*"],
      "js": ["google.js"],
      "run_at": "document_start"
    }
  ]
}